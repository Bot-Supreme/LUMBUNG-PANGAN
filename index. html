<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Selamat Datang di Gang Joker Digital</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&display=swap" rel="stylesheet">
<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: 'Nunito', sans-serif;
    background-color: #33b5e8;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px 60px;
  }

  .container {
    width: 100%;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  /* ── JUDUL ── */
  .title {
    font-size: 2.8rem;
    font-weight: 900;
    color: #ffffff;
    text-align: center;
    line-height: 1.15;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  /* ── KARTU ── */
  .card {
    background: #fffdf6;
    border-radius: 22px;
    padding: 20px 22px 26px;
    width: 100%;
    max-width: 340px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    box-shadow: 0 6px 32px rgba(0,0,0,0.10);
  }

  /* ── LABEL BADGE ── */
  .card-label {
    align-self: flex-start;
    background: #e8825a;
    color: #ffffff;
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    padding: 7px 18px;
    border-radius: 30px;
  }

  /* ── BUTTON LINK ── */
  .card-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 16px 24px;
    background: #2d4a8a;
    color: #ffffff;
    font-family: 'Nunito', sans-serif;
    font-size: 1rem;
    font-weight: 900;
    letter-spacing: 0.5px;
    text-decoration: none;
    border-radius: 14px;
    box-shadow: 0 4px 14px rgba(45,74,138,0.25);
    transition: background 0.18s, transform 0.15s, box-shadow 0.15s;
  }

  .card-btn:hover {
    background: #1e3570;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(45,74,138,0.30);
  }

  .card-btn:active {
    transform: scale(0.97);
  }

  .card-btn .btn-icon {
    font-size: 1.3rem;
    flex-shrink: 0;
  }
</style>
</head>
<body>

<div class="container">

  <!-- Judul -->
  <h1 class="title">Selamat Datang di<br>Gang Joker_Digital</h1>

  <!-- Kartu 1: Kas Gang Joker -->
  <div class="card">
    <div class="card-label">Kas Gang Joker</div>
    <a class="card-btn"
       href="https://bot-supreme.github.io/GankJoker_digital/Kas_Gang_Joker%20V%201.html"
       target="_blank" rel="noopener">
      <span class="btn-icon">🃏</span>
      Buka Kas Gang Joker
    </a>
  </div>

  <!-- Kartu 2: Lumbung Pangan RT -->
  <div class="card">
    <div class="card-label">Lumbung Pangan RT</div>
    <a class="card-btn"
       href="https://bot-supreme.github.io/GankJoker_digital/LP-26%20Ulti.html"
       target="_blank" rel="noopener">
      <span class="btn-icon">🌾</span>
      Buka Lumbung Pangan RT
    </a>
  </div>

</div>

</body>
</html>
